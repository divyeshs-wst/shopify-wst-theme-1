{% doc %}
  Widget: Button

  A link styled as a button, with filled / outline / text-link
  variants, three sizes, optional icon, and its own hover colors.

  There is no wrapper element. wst-attributes is rendered directly
  on the visible <a> (or <span> when there's no link), so it is the
  single root element for this block (required since "tag": null).
  That single element carries two class sources that both have to
  survive together:
    - the classes wst-attributes builds itself (wst-widget, wst-,
      hide-on-x, any custom_class the merchant typed in)
    - this widget's own classes (wst-button, the variant/size/
      alignment/full-width modifiers)
  wst-attributes' extra_class parameter is exactly for this: pass
  our own classes in and it appends them to its own list rather
  than overwriting it.
{% enddoc %}

{%- liquid
  assign settings = block.settings

  assign target_attr = ''
  if settings.open_in_new_tab
    assign target_attr = ' target="_blank" rel="noopener"'
  endif

  assign variant_class = 'wst-button--' | append: settings.button_style
  assign size_class = 'wst-button--' | append: settings.size
  assign align_class = 'wst-button--align-' | append: settings.alignment
  assign full_class = ''
  if settings.full_width
    assign full_class = ' wst-button--full'
  endif
  assign button_classes = 'wst-button ' | append: variant_class | append: ' ' | append: size_class | append: ' ' | append: align_class | append: full_class

  # Widget specific style variables, passed to wst-attributes
  capture button_vars
    if settings.text_color != blank and settings.text_color.alpha != 0.0
      echo '--wst-color: ' | append: settings.text_color | append: ';'
    endif
    if settings.hover_background_color != blank and settings.hover_background_color.alpha != 0.0
      echo '--wst-bg-hover: ' | append: settings.hover_background_color | append: ';'
    endif
    if settings.hover_text_color != blank and settings.hover_text_color.alpha != 0.0
      echo '--wst-color-hover: ' | append: settings.hover_text_color | append: ';'
    endif
  endcapture
-%}

{%- if settings.link != blank -%}
  <a href="{{ settings.link }}"{{ target_attr }} {% render 'wst-attributes', block: block, widget: 'button', extra_class: button_classes, extra_vars: button_vars %}>
    {%- if settings.icon != 'none' and settings.icon_position == 'left' -%}
      {%- render 'wst-button-icon', icon: settings.icon -%}
    {%- endif -%}
    <span class="wst-button__label">{{ settings.button_text | escape }}</span>
    {%- if settings.icon != 'none' and settings.icon_position == 'right' -%}
      {%- render 'wst-button-icon', icon: settings.icon -%}
    {%- endif -%}
  </a>
{%- else -%}
  <span {% render 'wst-attributes', block: block, widget: 'button', extra_class: button_classes, extra_vars: button_vars %} aria-disabled="true">
    {%- if settings.icon != 'none' and settings.icon_position == 'left' -%}
      {%- render 'wst-button-icon', icon: settings.icon -%}
    {%- endif -%}
    <span class="wst-button__label">{{ settings.button_text | escape }}</span>
    {%- if settings.icon != 'none' and settings.icon_position == 'right' -%}
      {%- render 'wst-button-icon', icon: settings.icon -%}
    {%- endif -%}
  </span>
{%- endif -%}

{% stylesheet %}
  .wst-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    box-sizing: border-box;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
    background-color: var(--wst-bg, #121212);
    background-image: var(--wst-bg-img, none), var(--wst-bg-gradient, none);
    background-position: var(--wst-bg-pos, center);
    background-size: var(--wst-bg-size, cover);
    background-repeat: var(--wst-bg-repeat, no-repeat);
    color: var(--wst-color, #ffffff);
    border: var(--wst-border, none);
    border-radius: var(--wst-radius, 6px);
    padding-top: var(--wst-pt, 12px);
    padding-bottom: var(--wst-pb, 12px);
    padding-left: var(--wst-pl, 28px);
    padding-right: var(--wst-pr, 28px);
  }

  .wst-button:hover,
  .wst-button:focus-visible {
    /* Only the flat background color changes on hover. A background
       image/gradient (if set via the shared Background settings) is
       a separate layer and intentionally stays as-is here - putting
       a plain color into background-image is invalid CSS and was
       silently doing nothing before this fix. */
    background-color: var(--wst-bg-hover, var(--wst-bg, #121212));
    color: var(--wst-color-hover, var(--wst-color, #ffffff));
  }

  .wst-button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* wst-engine.css maps --wst-ml to margin-right and --wst-mr to
     margin-left (swapped). That file is left as-is on purpose, so
     this corrects it just for Button. Both "wst-widget" and
     "wst-button" are on the same element here, so the combined
     selector has higher specificity than the engine's single-class
     .wst-widget rule and wins no matter which stylesheet loads
     first. */
  .wst-widget.wst-button {
    margin-left: var(--wst-ml, 0);
    margin-right: var(--wst-mr, 0);
  }

  /* Alignment: since there's no wrapper anymore, this button is a
     direct flex child of whatever Row or Column contains it. Auto
     margins are the standard way to position a single flex item
     (flexbox has no per-child justify-self). This intentionally
     overrides a manual Margin left/right value while active. */
  .wst-button.wst-button--align-left {
    margin-right: auto;
  }

  .wst-button.wst-button--align-center {
    margin-left: auto;
    margin-right: auto;
  }

  .wst-button.wst-button--align-right {
    margin-left: auto;
  }

  /* Size variants */
  .wst-button--small {
    font-size: 13px;
    padding-top: var(--wst-pt, 8px);
    padding-bottom: var(--wst-pb, 8px);
    padding-left: var(--wst-pl, 18px);
    padding-right: var(--wst-pr, 18px);
  }

  .wst-button--medium {
    font-size: 15px;
  }

  .wst-button--large {
    font-size: 17px;
    padding-top: var(--wst-pt, 16px);
    padding-bottom: var(--wst-pb, 16px);
    padding-left: var(--wst-pl, 36px);
    padding-right: var(--wst-pr, 36px);
  }

  /* Style variants: written after .wst-button so they win on equal specificity */
  .wst-button--outline {
    background-color: transparent;
    background-image: none;
    color: var(--wst-color, #121212);
    border: var(--wst-border, 2px solid var(--wst-color, #121212));
  }

  .wst-button--outline:hover,
  .wst-button--outline:focus-visible {
    background-color: var(--wst-bg-hover, var(--wst-color, #121212));
    background-image: none;
    color: var(--wst-color-hover, var(--wst-bg, #ffffff));
    border-color: var(--wst-bg-hover, var(--wst-color, #121212));
  }

  .wst-button--text {
    background-color: transparent;
    background-image: none;
    color: var(--wst-color, #121212);
    border: none;
    border-radius: 0;
    padding-left: 0;
    padding-right: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .wst-button--text:hover,
  .wst-button--text:focus-visible {
    background: none;
    transform: none;
    color: var(--wst-color-hover, var(--wst-bg, #121212));
    text-decoration-thickness: 2px;
  }

  .wst-button--full {
    width: 100%;
  }

  .wst-button[aria-disabled="true"] {
    cursor: default;
    opacity: 0.6;
    pointer-events: none;
  }

  .wst-button__label {
    display: inline-block;
  }

  .wst-button__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
{% endstylesheet %}

