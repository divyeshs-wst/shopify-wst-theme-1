{% doc %}
  Widget: Text

  Rich text content with two content modes:
  - Editor: Shopify's rich text editor (bold, italic, links, lists)
  - Code:   raw HTML for advanced use

  Includes alignment, text color, optional custom text size and
  line height, multi column text, and a drop cap. Shared style,
  animation and advanced settings come from 'wst-attributes'.
{% enddoc %}

{%- liquid
  assign settings = block.settings

  # Drop cap modifier class
  assign text_classes = ''
  if settings.drop_cap
    assign text_classes = 'wst-text--drop-cap'
  endif

  # Widget specific style variables, passed to wst-attributes
  capture text_vars
    if settings.alignment != blank
      echo '--wst-align: ' | append: settings.alignment | append: ';'
    endif
    if settings.text_color != blank and settings.text_color.alpha != 0.0
      echo '--wst-color: ' | append: settings.text_color | append: ';'
    endif
    if settings.custom_typography
      echo '--wst-text-size: ' | append: settings.font_size | append: 'px;'
      echo '--wst-text-lh: ' | append: settings.line_height | append: ';'
    endif
    if settings.columns_count > 1
      echo '--wst-text-cols: ' | append: settings.columns_count | append: ';'
      echo '--wst-text-col-gap: ' | append: settings.column_gap | append: 'px;'
    endif
  endcapture
-%}

<div {% render 'wst-attributes', block: block, widget: 'text', extra_class: text_classes, extra_vars: text_vars %}>
  {%- if settings.content_mode == 'code' -%}
    {{ settings.custom_html }}
  {%- else -%}
    {{ settings.text }}
  {%- endif -%}
</div>

{% stylesheet %}
  .wst-text {
    text-align: var(--wst-align, inherit);
    color: var(--wst-color, inherit);
    font-size: var(--wst-text-size, inherit);
    line-height: var(--wst-text-lh, inherit);
    columns: var(--wst-text-cols, auto);
    column-gap: var(--wst-text-col-gap, 40px);
  }

  .wst-text > *:first-child {
    margin-top: 0;
  }

  .wst-text > *:last-child {
    margin-bottom: 0;
  }

  .wst-text--drop-cap p:first-of-type::first-letter {
    float: left;
    font-size: 3.2em;
    line-height: 0.85;
    padding-right: 0.08em;
    font-weight: 600;
  }

  @media screen and (max-width: 749.98px) {
    .wst-text {
      columns: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Text",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "content_mode",
      "label": "Content mode",
      "options": [
        {
          "value": "editor",
          "label": "Editor"
        },
        {
          "value": "code",
          "label": "Code"
        }
      ],
      "default": "editor"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>",
      "visible_if": "{{ block.settings.content_mode == 'editor' }}"
    },
    {
      "type": "html",
      "id": "custom_html",
      "label": "HTML",
      "visible_if": "{{ block.settings.content_mode == 'code' }}"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "justify",
          "label": "Justified"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "checkbox",
      "id": "custom_typography",
      "label": "Use custom text size",
      "default": false
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Text size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.custom_typography }}"
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2.2,
      "step": 0.1,
      "default": 1.6,
      "visible_if": "{{ block.settings.custom_typography }}"
    },
    {
      "type": "range",
      "id": "columns_count",
      "label": "Text columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1,
      "info": "Text flows into multiple columns on desktop."
    },
    {
      "type": "range",
      "id": "column_gap",
