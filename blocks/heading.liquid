{% doc %}
  Widget: Heading

  A single heading with a choice of HTML tag, optional link,
  alignment and text color. Shared style, animation and advanced
  settings are rendered by the 'wst-attributes' snippet.
{% enddoc %}

{%- liquid
  assign settings = block.settings
  assign tag = settings.heading_tag | default: 'h2'

  # Widget specific style variables, passed to wst-attributes
  capture heading_vars
    if settings.alignment != blank
      echo '--wst-align: ' | append: settings.alignment | append: ';'
    endif
    if settings.text_color != blank and settings.text_color.alpha != 0.0
      echo '--wst-color: ' | append: settings.text_color | append: ';'
    endif
  endcapture
-%}

<{{ tag }} {% render 'wst-attributes', block: block, widget: 'heading', extra_vars: heading_vars %}>
  {%- if settings.link != blank -%}
    <a href="{{ settings.link }}" class="wst-heading__link">{{ settings.heading | escape }}</a>
  {%- else -%}
    {{ settings.heading | escape }}
  {%- endif -%}
</{{ tag }}>

{% stylesheet %}
  .wst-heading {
    text-align: var(--wst-align, inherit);
    color: var(--wst-color, inherit);
  }

  .wst-heading__link {
    color: inherit;
    text-decoration: none;
  }

  .wst-heading__link:hover {
    text-decoration: underline;
  }

  .wst-heading__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
{% endstylesheet %}

