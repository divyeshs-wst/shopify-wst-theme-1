{% doc %}
  Widget: Column

  A flexible item inside a Row and a vertical container for its
  own child blocks. Width is either automatic, sharing the row
  equally with the other columns, or a fixed percentage.
{% enddoc %}

{%- liquid
  assign settings = block.settings

  # Fixed width modifier
  assign column_classes = ''
  unless settings.auto_width
    assign column_classes = 'wst-column--fixed'
  endunless

  # Widget specific style variables, passed to wst-attributes
  capture column_vars
    unless settings.auto_width
      echo '--wst-col-w: ' | append: settings.width | append: '%;'
    endunless
    echo '--wst-justify: ' | append: settings.justify | append: ';'
    echo '--wst-align-items: ' | append: settings.align_items | append: ';'
    if settings.gap > 0
      echo '--wst-gap-row: ' | append: settings.gap | append: 'px;'
    endif
  endcapture
-%}

<div {% render 'wst-attributes', block: block, widget: 'column', extra_class: column_classes, extra_vars: column_vars %}>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .wst-column {
    display: flex;
    flex-direction: var(--wst-direction, column);
    justify-content: var(--wst-justify, flex-start);
    align-items: var(--wst-align-items, stretch);
    row-gap: var(--wst-gap-row, 0);
    column-gap: var(--wst-gap-col, 0);
    min-width: 0;
    flex: 1 1 0;
    /* height: 100%; */
  }

  .wst-column--fixed {
    flex: 0 1 var(--wst-col-w, 50%);
  }
{% endstylesheet %}

