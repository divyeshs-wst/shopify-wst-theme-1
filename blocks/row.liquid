{% doc %}
  Widget: Row

  The main layout container. Accepts any theme block, typically
  Columns. The outer element carries the background and spacing.
  The inner element is the flex or grid container that lays out
  the child blocks.
{% enddoc %}

{%- liquid
  assign settings = block.settings
  assign tag = settings.html_tag | default: 'div'

  # Modifier classes for layout behavior
  assign row_classes = ''
  if settings.layout == 'grid'
    assign row_classes = row_classes | append: ' wst-row--grid'
  endif
  if settings.stack_on_mobile
    assign row_classes = row_classes | append: ' wst-row--stack'
  endif

  # Inner container, boxed or full width
  assign inner_class = 'wst-row__inner'
  if settings.content_width == 'boxed'
    assign inner_class = inner_class | append: ' wst-row__inner--boxed'
  endif

  # Widget specific style variables, passed to wst-attributes
  capture row_vars
    if settings.layout == 'grid'
      echo '--wst-cols: ' | append: settings.grid_columns | append: ';'
      echo '--wst-cols-m: ' | append: settings.grid_columns_mobile | append: ';'
    else
      echo '--wst-direction: ' | append: settings.direction | append: ';'
      if settings.wrap
        echo '--wst-flex-wrap: wrap;'
      endif
    endif
    echo '--wst-justify: ' | append: settings.justify | append: ';'
    echo '--wst-align-items: ' | append: settings.align_items | append: ';'
    if settings.gap_row > 0
      echo '--wst-gap-row: ' | append: settings.gap_row | append: 'px;'
    endif
    if settings.gap_column > 0
      echo '--wst-gap-col: ' | append: settings.gap_column | append: 'px;'
    endif
    if settings.content_width == 'boxed'
      echo '--wst-content-width: ' | append: settings.content_max_width | append: 'px;'
    endif
    if settings.min_height_type == 'custom'
      echo '--wst-min-h: ' | append: settings.min_height | append: 'px;'
    elsif settings.min_height_type == 'screen'
      echo '--wst-min-h: 100svh;'
    endif
  endcapture
-%}

<{{ tag }} {% render 'wst-attributes', block: block, widget: 'row', extra_class: row_classes, extra_vars: row_vars %}>
  <div class="{{ inner_class }}">
    {% content_for 'blocks' %}
  </div>
</{{ tag }}>

{% stylesheet %}
  .wst-row__inner {
    display: flex;
    flex-direction: var(--wst-direction, row);
    justify-content: var(--wst-justify, flex-start);
    align-items: var(--wst-align-items, stretch);
    flex-wrap: var(--wst-flex-wrap, nowrap);
    row-gap: var(--wst-gap-row, 0);
    column-gap: var(--wst-gap-col, 0);
    min-height: inherit;
  }

  .wst-row__inner--boxed {
    width: 100%;
    max-width: var(--wst-content-width, 1200px);
    margin-left: auto;
    margin-right: auto;
  }

  .wst-row--grid .wst-row__inner {
    display: grid;
    grid-template-columns: repeat(var(--wst-cols, 2), minmax(0, 1fr));
  }

  @media screen and (max-width: 749.98px) {
    .wst-row--stack .wst-row__inner {
      flex-direction: column;
    }

    .wst-row--stack .wst-column,
    .wst-row--stack .wst-column--fixed {
      flex-basis: auto;
      width: 100%;
    }

    .wst-row--grid .wst-row__inner {
      grid-template-columns: repeat(var(--wst-cols-m, 1), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

